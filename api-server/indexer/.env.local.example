PONDER_NORMIES_ADDRESS=
PONDER_STORAGE_ADDRESS=
PONDER_MINTER_ADDRESSES=
# Optional: start block for the configured minter contracts. Falls back to
# PONDER_START_BLOCK if unset.
PONDER_MINTER_START_BLOCK=
PONDER_CANVAS_ADDRESS=
PONDER_ADAPTER_ADDRESS=
PONDER_START_BLOCK=
# Optional: start block for the Adapter8004 contract (use the deploy block to
# avoid scanning empty history). Falls back to PONDER_START_BLOCK if unset.
PONDER_ADAPTER_START_BLOCK=
PONDER_RPC_URL=
PONDER_CHAIN_ID=
DATABASE_URL=
# Default true. Set to false only when token_data and canvas_token_state are
# already complete and newer than the configured start block.
PONDER_BACKFILL_ON_START=true
PONDER_BACKFILL_CHUNK_SIZE=100
