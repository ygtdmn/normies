generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/agents-client"
}

datasource db {
  provider  = "postgresql"
  url       = env("AGENTS_DATABASE_URL")
  directUrl = env("AGENTS_DIRECT_URL")
}

enum AgentStatus {
  pending
  registered
}

model Agent {
  id                 Int         @id @default(autoincrement())
  tokenId            BigInt      @unique
  agentId            BigInt?     @unique
  chainId            Int

  traits             Json

  status             AgentStatus @default(pending)
  txHash             String?     @unique
  registeredBy       String
  createdBy          String

  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([registeredBy])
  @@index([status])
}
