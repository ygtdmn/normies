# RPC URLs (at least one required)
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_URL_FALLBACK_1=
RPC_URL_FALLBACK_2=

# Server
PORT=3000

# Cache (TTL in milliseconds)
CACHE_MAX_ENTRIES=10000
CACHE_TTL_MS=3600000
CANVAS_CACHE_TTL_MS=60000
CANVAS_INFO_CACHE_TTL_MS=60000
CANVAS_STATUS_CACHE_TTL_MS=300000

# Rate Limiting (requests per minute)
RATE_LIMIT_MAX=60

# Ponder indexer API URL (required for API server startup)
PONDER_API_URL=http://localhost:42069

# Public host this api-server is served at — used to build absolute URLs
# in the /agents/metadata response (image, services.endpoint). Without it,
# defaults to https://api.normies.art.
PUBLIC_API_BASE=https://api.normies.art
